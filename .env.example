# NBalance — Configuration
# Copier ce fichier en .env et adapter les valeurs

# PostgreSQL
POSTGRES_DB=nbalance
POSTGRES_USER=nbalance
POSTGRES_PASSWORD=nbalance_dev

APP_NAME: str = "NBalance 1Max"
APP_VERSION: str = "0.1.1"



# Ports
DB_PORT=5432
API_PORT=8000
FRONT_PORT=80

# Tag des images Docker (géré automatiquement par le CI)
TAG=latest
